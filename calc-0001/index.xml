          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>
    Notes on optimal control based on the course ECE6553-Optimal Control at Gatech 2026 Spring.
</html:p>
            <fr:tree show-metadata="false">
              <fr:frontmatter>
                <fr:authors>
                  <fr:author>
                    <fr:link href="/boat/" title="Zihang Zeng" uri="https://boatnotabot.com/boat/" display-uri="boat" type="local">Zihang Zeng</fr:link>
